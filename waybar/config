{
  "layer": "top",
  "position": "top",
  "modules-left": [
    "sway/workspaces"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "custom/claude",
    "custom/help",
    "custom/theme",
    "custom/scale",
    "cpu",
    "pulseaudio",
    "backlight",
    "custom/argon-battery",
    "tray",
    "custom/power"
  ],
  "cpu": {
    "format": "¾░ıø {usage}%",
    "interval": 5,
    "tooltip": true,
    "on-click": "foot -e socktop --demo"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "¾░Øş muted",
    "format-bluetooth": "¾░é░ {volume}%",
    "format-bluetooth-muted": "¾░é▓ muted",
    "format-icons": {
      "headphone": "¾░ïï",
      "hands-free": "¾░éæ",
      "headset": "¾░ïÄ",
      "phone": "",
      "portable": "",
      "car": "",
      "default": [
        "¾░ò┐",
        "¾░ûÇ",
        "¾░ò¥"
      ]
    },
    "tooltip": true,
    "tooltip-format": "{desc} ÔÇö {volume}%\nRight-click: choose output",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "audio-sink-picker"
  },
  "network": {
    "format-wifi": "¾░ñ¿ {essid}",
    "format-ethernet": "¾░êÇ {ipaddr}",
    "format-disconnected": "¾░ñ¡ offline",
    "tooltip": true,
    "on-click": "foot -e nmtui"
  },
  "clock": {
    "format": "{:%a %b %d  %H:%M}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "format": {
        "today": "<b><span background=\"#8caaee\" color=\"#303446\">{}</span></b>"
      }
    }
  },
  "backlight": {
    "format": "¾░âá {percent}%",
    "tooltip": false
  },
  "custom/claude": {
    "format": "¾░ùÜ ",
    "tooltip": false,
    "on-click": "foot -e ~/.local/bin/claude",
    "on-click-right": "~/.local/bin/claude-prompt"
  },
  "custom/help": {
    "format": "¾░ïû ",
    "tooltip": false,
    "on-click": "~/.local/bin/sway-help"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 8
  },
  "custom/argon-battery": {
    "exec": "/usr/local/bin/argon-battery-rs",
    "return-type": "json",
    "interval": 1,
    "tooltip": true,
    "on-click": "~/.local/bin/power-mode toggle"
  },
  "custom/theme": {
    "format": "¾░Åİ ",
    "tooltip": false,
    "on-click": "swaymsg exec ~/.local/bin/switch-theme\\ --picker"
  },
  "custom/scale": {
    "exec": "~/.local/bin/sway-scale get",
    "interval": 2,
    "format": "¾░ıë {}",
    "tooltip": false,
    "on-click": "swaymsg exec ~/.local/bin/sway-scale\\ picker"
  },
  "custom/power": {
    "format": "ÔÅ╗",
    "tooltip": false,
    "on-click": "~/.local/bin/powermenu"
  }
}
