#!/usr/bin/env python3
"""Disable touchpad while typing for sway.

Monitors keyboard evdev events and disables the touchpad via swaymsg
for a configurable timeout after each keypress. Works around DWT not
functioning on USB combo keyboard/touchpad devices (like the AMIRA
keyboard in the Argon ONE UP case).

Requires: input group membership, python3, swaymsg
"""

import os
import sys
import glob
import struct
import select
import subprocess
import time

TIMEOUT = 0.5  # seconds after last keypress to re-enable
TOUCHPAD = "type:touchpad"
EVENT_SIZE = 24  # sizeof(struct input_event) on 64-bit
EV_KEY = 0x01


def find_keyboard():
    """Find the main keyboard evdev device (not consumer/power subdevices)."""
    # Try by-id first for stable naming
    by_id = "/dev/input/by-id/usb-AMIRA-KEYBOAR_USB_KEYBOARD-event-kbd"
    if os.path.exists(by_id):
        return os.path.realpath(by_id)

    # Fallback: scan all event devices
    for sysdir in sorted(glob.glob("/sys/class/input/event*")):
        try:
            name = open(os.path.join(sysdir, "device/name")).read().strip()
            if "AMIRA" not in name:
                continue
            # Full keyboards have large key capability bitmaps
            caps = open(os.path.join(sysdir, "device/capabilities/key")).read().strip()
            if len(caps) > 20:
                return f"/dev/input/{os.path.basename(sysdir)}"
        except (OSError, IOError):
            continue
    return None


def swaymsg_input(state):
    subprocess.Popen(
        ["swaymsg", "input", TOUCHPAD, "events", state],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def main():
    kb = find_keyboard()
    if not kb:
        print("trackpad-guard: keyboard not found", file=sys.stderr)
        sys.exit(1)

    try:
        fd = os.open(kb, os.O_RDONLY | os.O_NONBLOCK)
    except PermissionError:
        print("trackpad-guard: permission denied — add user to input group", file=sys.stderr)
        sys.exit(1)

    disabled = False
    last_key = 0.0

    try:
        while True:
            timeout = max(0.01, TIMEOUT - (time.monotonic() - last_key)) if disabled else None
            ready, _, _ = select.select([fd], [], [], timeout)

            if ready:
                try:
                    data = os.read(fd, EVENT_SIZE * 64)
                    for i in range(0, len(data) - EVENT_SIZE + 1, EVENT_SIZE):
                        _, _, ev_type, _, value = struct.unpack("llHHi", data[i : i + EVENT_SIZE])
                        if ev_type == EV_KEY and value == 1:  # key press
                            last_key = time.monotonic()
                            if not disabled:
                                swaymsg_input("disabled")
                                disabled = True
                except BlockingIOError:
                    pass

            # Re-enable after timeout
            if disabled and (time.monotonic() - last_key) >= TIMEOUT:
                swaymsg_input("enabled")
                disabled = False
    except KeyboardInterrupt:
        pass
    finally:
        os.close(fd)
        swaymsg_input("enabled")


if __name__ == "__main__":
    main()
