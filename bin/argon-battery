#!/bin/bash
output=$(sudo /usr/bin/python3 /etc/argon/argononeupd.py GETBATTERY 2>/dev/null)
percent=$(echo "$output" | grep -oP '\d+')
charging=$(echo "$output" | grep -qi 'charging' && echo 1 || echo 0)

if [ -z "$percent" ]; then
    echo '{"text": "σΑ¹Ι ?%", "tooltip": "Battery status unavailable", "class": "unknown"}'
    exit 0
fi

if [ "$charging" = "1" ]; then
    if [ "$percent" -ge 80 ]; then icon="σΑ²Ö"
    elif [ "$percent" -ge 60 ]; then icon="σΑ²³"
    elif [ "$percent" -ge 40 ]; then icon="σΑ²à"
    elif [ "$percent" -ge 20 ]; then icon="σΑ²Ü"
    else icon="σΑΔü"
    fi
    class="charging"
    status="Charging"
else
    if [ "$percent" -ge 80 ]; then
        icon="σΑ¹Ι"; class="good"
    elif [ "$percent" -ge 60 ]; then
        icon="σΑ¹Ω"; class="good"
    elif [ "$percent" -ge 40 ]; then
        icon="σΑ¹Φ"; class="moderate"
    elif [ "$percent" -ge 20 ]; then
        icon="σΑ¹Κ"; class="warning"
    else
        icon="σΑ²É"; class="critical"
    fi
    status="Discharging"
fi

echo "{\"text\": \"$icon $percent%\", \"tooltip\": \"Argon Battery: $status $percent%\", \"class\": \"$class\"}"
