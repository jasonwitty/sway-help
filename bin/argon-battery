#!/bin/bash
output=$(sudo /usr/bin/python3 /etc/argon/argononeupd.py GETBATTERY 2>/dev/null)
percent=$(echo "$output" | grep -oP '\d+')

if [ -z "$percent" ]; then
    echo '{"text": "箚겧 ?%", "tooltip": "Battery status unavailable", "class": "unknown"}'
    exit 0
fi

if [ "$percent" -ge 80 ]; then
    icon="箚겧"
    class="good"
elif [ "$percent" -ge 60 ]; then
    icon="箚겳"
    class="good"
elif [ "$percent" -ge 40 ]; then
    icon="箚겮"
    class="moderate"
elif [ "$percent" -ge 20 ]; then
    icon="箚겫"
    class="warning"
else
    icon="箚굛"
    class="critical"
fi

echo "{\"text\": \"$icon $percent%\", \"tooltip\": \"Argon Battery: $percent%\", \"class\": \"$class\"}"
