#!/bin/bash
# Direct I2C brightness control for Argon ONE UP display
# Sets panel backlight in ~1ms via DDC/CI over I2C bus 14

CACHE_FILE="/tmp/.brightness_level"
WOBSOCK="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/wob.sock"
STEP=5
MIN=5
MAX=100

# Get current brightness from cache, or query DDC
if [[ -f "$CACHE_FILE" ]]; then
    current=$(cat "$CACHE_FILE")
else
    current=$(ddcutil --bus 14 getvcp 10 -t 2>/dev/null | awk '{print $4}')
    [[ -z "$current" ]] && current=50
fi

case "$1" in
    up)   new=$(( current + STEP > MAX ? MAX : current + STEP )) ;;
    down) new=$(( current - STEP < MIN ? MIN : current - STEP )) ;;
    *)    echo "Usage: brightness up|down"; exit 1 ;;
esac

# Set brightness directly via I2C (~1ms)
python3 -c "
import os, fcntl
addr, val = 0x37, $new
s, l, op, vcp, vh, vl = 0x51, 0x84, 0x03, 0x10, 0x00, val
chk = (addr << 1) ^ s ^ l ^ op ^ vcp ^ vh ^ vl
fd = os.open('/dev/i2c-14', os.O_RDWR)
fcntl.ioctl(fd, 0x0703, addr)
os.write(fd, bytes([s, l, op, vcp, vh, vl, chk]))
os.close(fd)
"

# Cache and show indicator
echo "$new" > "$CACHE_FILE"
echo "$new" > "$WOBSOCK"
