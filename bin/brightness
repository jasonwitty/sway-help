#!/bin/bash
# DDC brightness control with wob indicator
CACHE_FILE="/tmp/.brightness_level"
WOBSOCK="/run/user/1000/wob.sock"
STEP=5

# Get current brightness from cache, or query DDC
if [[ -f "$CACHE_FILE" ]]; then
    current=$(cat "$CACHE_FILE")
else
    current=$(ddcutil getvcp 10 -t 2>/dev/null | awk '{print $4}')
    [[ -z "$current" ]] && current=50
fi

case "$1" in
    up)   new=$(( current + STEP > 100 ? 100 : current + STEP )) ;;
    down) new=$(( current - STEP < 0 ? 0 : current - STEP )) ;;
    *)    echo "Usage: brightness up|down"; exit 1 ;;
esac

# Cache and show indicator immediately (never blocks)
echo "$new" > "$CACHE_FILE"
echo "$new" > "$WOBSOCK"

# Kill any previous ddcutil and apply the latest value
pkill -f "ddcutil setvcp 10" 2>/dev/null
ddcutil setvcp 10 "$new" 2>/dev/null &
disown
